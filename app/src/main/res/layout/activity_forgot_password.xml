<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Background image -->
    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:alpha="0.6"
        android:scaleType="centerCrop"
        android:src="@drawable/backgorund_image"
        android:contentDescription="Background" />

    <LinearLayout
        android:layout_width="271dp"
        android:orientation="vertical"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="176dp"
            android:layout_height="66dp"
            android:layout_marginBottom="20dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot Password"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter your email address to receive a password reset link"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/emailAddressEdt"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/edit_text_border"
            android:drawableStart="@drawable/user_icon"
            android:drawablePadding="8dp"
            android:textColorHint="@color/gray_text"
            android:drawableTint="@color/gray_text"
            android:hint="Email Address"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/loader"
            android:layout_width="match_parent"
            android:visibility="gone"
            android:background="@drawable/primary_button"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:layout_height="37dp">

            <ProgressBar
                android:layout_width="35dp"
                android:indeterminate="true"
                android:indeterminateTint="@android:color/white"
                android:layout_height="35dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/submitButton"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:textColor="#FFFFFF"
            android:text="Submit"
            android:textSize="15sp"
            android:background="@drawable/primary_button"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/backToLoginBtn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Back to Login"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

</RelativeLayout>
